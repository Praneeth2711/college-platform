generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model College {
  id                  Int       @id @default(autoincrement())
  name                String
  location            String
  city                String
  state               String
  fees                Int
  rating              Float
  placementPercentage Float
  establishedYear     Int
  type                String
  description         String
  imageUrl            String?
  acceptedExams       String[]

  courses             Course[]
  savedBy             SavedCollege[]

  createdAt           DateTime @default(now())
}

model Course {
  id         Int      @id @default(autoincrement())
  courseName String
  duration   String

  collegeId  Int
  college    College  @relation(fields: [collegeId], references: [id])
}

model User {
  id            Int            @id @default(autoincrement())
  name          String?
  email         String         @unique
  password      String
  savedColleges SavedCollege[]
  createdAt     DateTime       @default(now())
}

model SavedCollege {
  id        Int      @id @default(autoincrement())
  userId    Int
  collegeId Int
  user      User     @relation(fields: [userId], references: [id])
  college   College  @relation(fields: [collegeId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, collegeId])
}
