generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model College {
  id                  Int       @id @default(autoincrement())
  name                String
  location            String
  city                String
  state               String
  fees                Int
  rating              Float
  placementPercentage Float
  establishedYear     Int
  type                String
  description         String
  imageUrl            String?

  courses             Course[]

  createdAt           DateTime @default(now())
}

model Course {
  id         Int      @id @default(autoincrement())
  courseName String
  duration   String

  collegeId  Int
  college    College  @relation(fields: [collegeId], references: [id])
}
